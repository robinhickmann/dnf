[Unit]
Description=DNF Authoritative DNS Server
Documentation=https://github.com/robinhickmann/dnf
After=network.target
Wants=network.target

[Service]
Type=simple
ExecStart=/usr/local/bin/dnfd
Restart=on-failure
RestartSec=5s

CapabilityBoundingSet=CAP_NET_BIND_SERVICE
WorkingDirectory=/etc/dnfd

ProtectSystem=strict
ProtectHome=yes
PrivateTmp=yes

[Install]
WantedBy=multi-user.target
